# ── QR Code Generator — Environment Configuration ──────────────────────────────
#
# Copy this file to .env and adjust the values before deploying.
#
#   cp .env.example .env
#   nano .env
#   docker compose up -d
#
# ── Frontend ────────────────────────────────────────────────────────────────────

# Public URL of the backend API as seen by browser clients.
# Set this to the IP address or domain name of your VM.
# Example: http://192.168.1.42:8000  or  https://api.example.com
PUBLIC_API_URL=http://localhost:8000

# ── URL shortener (optional — only needed with --profile shortener) ─────────────

# Public hostname used in shortened URLs (no trailing slash).
RS_INSTANCE_HOSTNAME=https://s.rezel.net

# Override the URL the backend uses to reach rs-short.
# (Defaults to http://rs-short:8080 when running inside Docker Compose.)
# RS_SHORT_URL=http://rs-short:8080
