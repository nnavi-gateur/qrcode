# ── QR Code Generator — Environment Configuration ──────────────────────────────
#
# Copy this file to .env and adjust the values before deploying.
#
#   cp .env.example .env
#   nano .env
#   docker compose up -d
#
# ── Frontend ────────────────────────────────────────────────────────────────────

# Public URL of the backend API as seen by browser clients.
# For local testing on the same network: http://<your-machine-ip>:8000
# For production: https://api.example.com
PUBLIC_API_URL=http://<your-machine-ip>:8000

# ── URL shortener (rs-short) ────────────────────────────────────────────────────

# Public hostname used in shortened URLs (no trailing slash).
# This controls the URL that ends up in the QR code — set it to your
# production domain to always get clean links.
# For local testing where you want QR codes to work on phones on the
# same network, you can temporarily set this to http://<your-ip>:8080.
# For production: https://qr.rezel.net/s
RS_INSTANCE_HOSTNAME=https://qr.rezel.net/s

# Override the URL the backend uses to reach rs-short internally.
# (Defaults to http://rs-short:8080 when running inside Docker Compose.)
# RS_SHORT_URL=http://rs-short:8080

# ── rs-short secrets (optional — auto-generated at startup if not set) ──────────

# Base64-encoded 64-byte key for cookie signing.
# Generate with: openssl rand -base64 64 | tr -d '\n'
# RS_COOKIE_KEY=

# Password to flag links as phishing (alphanumeric, >16 chars).
# RS_PHISHING_PASSWORD=
